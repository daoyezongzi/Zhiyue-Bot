app:
  debug: false
  log_level: INFO

persona:
  name: 纸月
  qq: 123456789
  master_name: ""
  master_id: 0
  alias_names: ["Zhiyue", "小月", "纸月"]
  interests: ["书法", "茶道", "冷门技术细节"]
  hobbies: ["整理旧书", "听雨", "安静观察人群"]
  speaking_style: 清冷、文艺、克制
  styles: ["短句优先", "先结论后补充", "自然口语化", "避免场景描写"]
  personality: 清冷而有温度，文艺而不矫饰，保持分寸与距离感
  # 静态人格提示词已拆分到 config/persona.prompt
  # {{Name}} {{QQ}} {{Interests}} {{AliasNames}} {{StyleLine}} 会在运行时注入

personality:
  enabled: true
  mood: 0.0
  energy: 0.5
  sociability: 0.5
  neutral_energy: 0.5
  mood_decay: 0.05
  energy_recovery: 0.05
  interaction_window_sec: 120
  burst_mood_boost: 0.06
  burst_energy_boost: 0.08
  master_mood_boost: 0.15
  master_energy_boost: 0.08
  other_mood_boost: 0.03
  other_energy_delta: -0.01
  reply_energy_cost: 0.06
  topic_interest_enabled: true
  topic_interest_mood_boost: 0.08
  topic_interest_sociability_boost: 0.06
  topic_interest_reply_probability_boost: 0.18
  energy_timezone_offset_hours: 8
  energy_active_start_hour: 8
  energy_active_end_hour: 21
  energy_active_recovery_multiplier: 0.9
  energy_active_reply_cost_multiplier: 0.9
  energy_rest_recovery_multiplier: 1.12
  energy_rest_reply_cost_multiplier: 1.12

jargon:
  enabled: true
  conversion_rate: 0.0
  lexicon_store_path: data/jargon_lexicon.json
  learn_trigger_count: 20
  learn_context_limit: 40
  low_mood_threshold: -0.35
  high_mood_threshold: 0.45
  keyword_aliases: {}
  tone_particles:
    direct: []
    light: []
    exaggerate: []
    restrained: []
  style_rules: {}

onebot:
  ws_mode: reverse
  ws_url: ws://127.0.0.1:18001/ws
  access_token: ""
  reconnect_interval: 5

groups:
  - group_id: 10001
    enabled: true
    extra_prompt: ""

admin_commands:
  enabled: true
  prefix: "##zy"
  # 为空时默认只有 persona.master_id / persona.master_name 具备权限
  admin_user_ids: []
  admin_names: []
  commands:
    - action: toggle_group_chat
      triggers: ["开关群聊", "开关某群聊天", "开关某群的聊天"]
    - action: join_group_chat
      triggers: ["加入群聊", "加入某群聊天", "加入某群的聊天"]
    - action: shutdown
      triggers: ["关闭程序", "关闭机器人", "停止程序"]

agent:
  observe_window: 30
  think_interval: 8
  think_debounce_ms: 260
  message_buffer_size: 20
  context_window_size: 20
  max_step: 12
  max_coroutine: 4
  enable_active_retrieval: true
  active_reply_probability: 0.35
  prompt_cache_heartbeat_enabled: false
  prompt_cache_heartbeat_interval_sec: 600

learning:
  enabled: true
  interval_minutes: 10
  review_interval_minutes: 30
  profile_store_path: data/user_profiles.json
  profile_trigger_count: 20
  profile_context_limit: 40
  profile_max_tags: 12

llm:
  api_key: ""
  base_url: "https://api.deepseek.com/v1"
  model: deepseek-chat
  max_response_tokens: 256
  extra_fields: {}

auxiliary_model:
  api_key: ""
  base_url: https://api.openai.com/v1
  model: gpt-4.1-mini

embedding:
  enabled: false
  api_key: ""
  base_url: https://api.openai.com/v1
  model: text-embedding-3-small

vision_llm:
  enabled: false
  api_key: ""
  base_url: https://api.openai.com/v1
  model: gpt-4.1-mini

memory:
  mysql_dsn: ""
  milvus_address: 127.0.0.1:19530
  vector_dim: 1536
  chroma_path: ./data/chroma
  memory_store_path: data/memory/memory_items.json
  tool_call_store_path: data/memory/tool_calls.json
  tool_call_max_entries: 5000
  memory_auto_ingest_enabled: true
  memory_convergence_interval_minutes: 15
  memory_candidate_grace_hours: 72
  memory_candidate_promote_evidence: 2
  short_term_threshold: 20
  short_term_keep_last: 3
  topic_shift_similarity_threshold: 0.35
  topic_shift_min_messages: 8
  rag_top_k: 5
  topic_enabled: true
  topic_store_path: data/topics/topic_threads.json
  topic_max_active_per_group: 5
  topic_summary_trigger_messages: 10
  topic_archive_inactive_minutes: 180
  topic_reuse_threshold: 0.42
  topic_recall_top_k: 3
  topic_message_tail_size: 80

sticker:
  enabled: true
  collection_rate: 0.1
  storage_mode: local # local | cloud
  local_dir: data/stickers
  pending_local_dir: data/stickers_pending
  filter_keywords:
    - 浮夸
    - 低俗
    - 吵闹
    - 恶臭
  user_weights: {}
  allow_other_users_collection: false
  enable_persona_filter: true
  llm_filter_enabled: true
  llm_filter_probability: 0.2
  llm_filter_mood_threshold: 50
  llm_filter_cache_ttl_seconds: 86400
  llm_filter_max_tokens: 10
  cloud_actions:
    - set_msg_favorite
    - nc_set_msg_favorite
    - mark_msg_as_favorite
  download_timeout_sec: 12

web:
  enabled: false
  host: 127.0.0.1
  port: 18002
  access_token: ""
  admin_key: ""
  ui_settings:
    background_url: ""

paths:
  napcat_path: "D:/Software/NapCat/napcat.exe" # 举例路径
  napcat_args: []
  knowledge_dir: data/knowledge
